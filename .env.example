# Aegis Mail AI — environment template. Copy to `.env` and fill in.
# NEVER commit the real .env (see .gitignore).

# --- App ---
ENVIRONMENT=development
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# --- LLM: OpenAI-compatible provider (default GroqCloud). ---
# Get a free key at https://console.groq.com  (Groq != xAI's "Grok").
# To use a different provider, just change these three values:
#   xAI/Grok:  LLM_BASE_URL=https://api.x.ai/v1        LLM_MODEL=grok-4.3
#   OpenAI:    LLM_BASE_URL=https://api.openai.com/v1  LLM_MODEL=gpt-4o-mini
LLM_API_KEY=
LLM_MODEL=llama-3.3-70b-versatile
LLM_BASE_URL=https://api.groq.com/openai/v1

# --- Embeddings (Groq has no embeddings API; default = Google Gemini free tier). ---
# Get a free key at https://aistudio.google.com/apikey
# Needed from Phase 2 for pgvector semantic search. EMBEDDING_DIM MUST match the
# vector(...) dimension in backend/db/schema.sql (768 for Gemini text-embedding-004).
# To use OpenAI instead: EMBEDDING_MODEL=text-embedding-3-small,
#   EMBEDDING_BASE_URL=https://api.openai.com/v1, EMBEDDING_DIM=1536 (and edit schema).
EMBEDDING_API_KEY=
EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
EMBEDDING_DIM=768

# --- Database: hosted Postgres with pgvector (Neon or Supabase). ---
# No Docker: create a free project and paste its connection string here.
#   Neon:     https://neon.tech       (pgvector supported)
#   Supabase: https://supabase.com    (pgvector supported)
# Needed from Phase 2 onward; Phase 0 boots without it.
# Example: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=

# --- Google OAuth (Phase 1+) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback

# --- Secrets: Fernet key to encrypt OAuth tokens at rest (Phase 1). ---
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=

# --- Frontend ---
BACKEND_URL=http://localhost:8000
